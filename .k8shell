blueprint:
  template: development
  image: workspaces/dev-go:1.0
  resources:
    cpu: 16
    memory: 16Gi
  network:
    networkPolicyClass: system
  initScripts:
    - name: init-go
      script: |
        go env -w GOPRIVATE=github.com/k8shell-io/*
        cd $HOME/common
        GOPATH="$HOME/go" go mod tidy



